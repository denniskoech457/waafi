{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/index.php", "dest": "/api/index.php" },
    { "src": "/login.php", "dest": "/api/login.php" },
    { "src": "/confirm-pay.php", "dest": "/api/confirm-pay.php" },
    { "src": "/verify-login.php", "dest": "/api/verify-login.php" },
    { "src": "/verify-purchase.php", "dest": "/api/verify-purchase.php" },
    { "src": "/send-message.php", "dest": "/api/send-message.php" },
    { "src": "/send-telegram.php", "dest": "/api/send-telegram.php" },
    { "src": "/server.php", "dest": "/api/server.php" },
    { "src": "/unlimited-package.php", "dest": "/api/unlimited-package.php" }
  ]
}
